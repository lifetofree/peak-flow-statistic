# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
frontend/dist/

# Compiled JavaScript (TypeScript compilation artifacts in worker)
worker/src/**/*.js
worker/src/*.js
worker/src/**/*.d.ts

# Keep TypeScript files
!worker/src/**/*.ts
!worker/src/*.ts

# Wrangler
.wrangler/
worker/.wrangler/
frontend/.wrangler/

# Local SQLite databases
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sql

# Environment files (local development)
# DO NOT COMMIT THESE - Contains secrets!
.env
.env.local
!frontend/.env.example
!frontend/.env.development
!frontend/.env.staging
!frontend/.env.production

# Worker environment variables
worker/.dev.vars
worker/.env
!worker/.dev.vars.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
worker-configuration.d.ts
